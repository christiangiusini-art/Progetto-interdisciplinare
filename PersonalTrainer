

import java.util.ArrayList;

public class PersonalTrainer {
    private String nome;
    private String cognome;
    private String specializzazione;
    private int anniEsperienza;
    private double costoOrario;
    private boolean disponibile;
    private ArrayList<String> certificazioni;
    
    // Lista statica di personal trainer disponibili
    private static ArrayList<PersonalTrainer> trainerDisponibili = new ArrayList<>();
    
    static {
        // Inizializzazione trainer predefiniti
        ArrayList<String> cert1 = new ArrayList<>();
        cert1.add("Certified Personal Trainer");
        cert1.add("Nutrition Specialist");
        trainerDisponibili.add(new PersonalTrainer("Marco", "Bianchi", "Bodybuilding", 8, 35.0, cert1, true));
        
        ArrayList<String> cert2 = new ArrayList<>();
        cert2.add("Fitness Coach");
        cert2.add("Weight Loss Specialist");
        trainerDisponibili.add(new PersonalTrainer("Laura", "Verdi", "Dimagrimento", 5, 30.0, cert2, true));
        
        ArrayList<String> cert3 = new ArrayList<>();
        cert3.add("Functional Training Expert");
        cert3.add("Kinesiology Degree");
        trainerDisponibili.add(new PersonalTrainer("Andrea", "Neri", "Allenamento Funzionale", 10, 40.0, cert3, true));
        
        ArrayList<String> cert4 = new ArrayList<>();
        cert4.add("Powerlifting Coach");
        cert4.add("Strength Training Certification");
        trainerDisponibili.add(new PersonalTrainer("Sofia", "Rossi", "Powerlifting", 6, 38.0, cert4, true));
        
        ArrayList<String> cert5 = new ArrayList<>();
        cert5.add("Physical Therapy");
        cert5.add("Postural Re-education");
        trainerDisponibili.add(new PersonalTrainer("Luca", "Gialli", "Riabilitazione", 12, 45.0, cert5, true));
    }
    
    public PersonalTrainer() {}
    
    public PersonalTrainer(String nome, String cognome, String specializzazione, 
                          int anniEsperienza, double costoOrario, ArrayList<String> certificazioni, boolean disponibile) {
        this.nome = nome;
        this.cognome = cognome;
        this.specializzazione = specializzazione;
        this.anniEsperienza = anniEsperienza;
        this.costoOrario = costoOrario;
        this.disponibile = disponibile;
        this.certificazioni = certificazioni;
    }
    
    // Getters e Setters
    public String getNome() { return nome; }
    public void setNome(String nome) { this.nome = nome; }
    public String getCognome() { return cognome; }
    public void setCognome(String cognome) { this.cognome = cognome; }
    public String getSpecializzazione() { return specializzazione; }
    public void setSpecializzazione(String specializzazione) { this.specializzazione = specializzazione; }
    public int getAnniEsperienza() { return anniEsperienza; }
    public void setAnniEsperienza(int anniEsperienza) { this.anniEsperienza = anniEsperienza; }
    public double getCostoOrario1() { return costoOrario; }
    public void setCostoOrario(double costoOrario) { this.costoOrario = costoOrario; }
    public boolean isDisponibile() { return disponibile; }
    public void setDisponibile(boolean disponibile) { this.disponibile = disponibile; }
    public ArrayList<String> getCertificazioni() { return certificazioni; }
    
    public String getNomeCompleto() {
        return nome + " " + cognome;
    }
    
    public static ArrayList<PersonalTrainer> getTrainerDisponibili() {
        return trainerDisponibili;
    }
    
    public static PersonalTrainer getTrainerByIndex(int index) {
        if (index >= 0 && index < trainerDisponibili.size()) {
            return trainerDisponibili.get(index);
        }
        return null;
    }
    
    @Override
    public String toString() {
        return nome + " " + cognome + " - " + specializzazione + 
               " | Esperienza: " + anniEsperienza + " anni | €" + costoOrario + "/ora" +
               (disponibile ? " | ✅ Disponibile" : " | ❌ Non disponibile");
    }

	public int getCostoOrario() {
		// TODO Auto-generated method stub
		return 0;
	}
}
