    private JPanel createUtenteInfoPanel() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBorder(BorderFactory.createTitledBorder("👤 Utente Corrente"));
        
        JLabel infoLabel = new JLabel("Nessun utente selezionato");
        infoLabel.setFont(new Font("Arial", Font.PLAIN, 12));
        panel.add(infoLabel, BorderLayout.CENTER);
        
        Timer timer = new Timer(1000, e -> {
            if (utenteCorrente != null) {
                infoLabel.setText("✓ " + utenteCorrente.getNomeCompleto() + 
                    " | Età: " + utenteCorrente.getEta() + 
                    " | Peso: " + utenteCorrente.getPeso() + "kg" +
                    " | Abbonamento: " + utenteCorrente.getTipoAbbonamento());
            } else {
                infoLabel.setText("⚠️ Nessun utente selezionato - Crea o carica un utente");
            }
        });
        timer.start();
        
        return panel;
    }
    
    private void updateUtenteInfoDisplay() {
        if (utenteCorrente != null) {
            log("Informazioni utente: " + utenteCorrente.getNomeCompleto() + 
                " | Età: " + utenteCorrente.getEta() + 
                " | Peso: " + utenteCorrente.getPeso() + "kg");
            
            // Controlla richieste personal trainer in sospeso
            ArrayList<RichiestaPersonalTrainer> richieste = RichiestaPersonalTrainer.getRichiestePerUtente(utenteCorrente);
            int inAttesa = 0;
            for (RichiestaPersonalTrainer r : richieste) {
                if (r.getStato().equals("In attesa")) {
                    inAttesa++;
                }
            }
            if (inAttesa > 0) {
                log("⚠️ Hai " + inAttesa + " richieste Personal Trainer in attesa");
            }
        }
    }
    
    private void createAbbonamentoPanel() {
