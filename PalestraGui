        tableEserciziDisponibili.setRowHeight(25);
        tableEserciziDisponibili.getTableHeader().setFont(new Font("Arial", Font.BOLD, 12));
        
        JScrollPane scrollEsercizi = new JScrollPane(tableEserciziDisponibili);
        scrollEsercizi.setBorder(BorderFactory.createTitledBorder("📚 Catalogo Esercizi"));
        panelEsercizi.add(scrollEsercizi, BorderLayout.CENTER);
        
