    private void log(String message) {
        if (areaLog != null) {
            areaLog.append("[" + new SimpleDateFormat("HH:mm:ss").format(new java.util.Date()) + "] " + message + "\n");
            areaLog.setCaretPosition(areaLog.getDocument().getLength());
        }
    }
    
