    private JComponent buildSchedaPreview() {
        JPanel p = card();
        p.setLayout(new BorderLayout(0, 12));

        JPanel head = new JPanel(new BorderLayout());
        head.setOpaque(false);
        JLabel l = new JLabel("SCHEDA ATTIVA");
        l.setForeground(FG);
        l.setFont(new Font("SansSerif", Font.BOLD, 18));
        JButton b = secondaryButton("APRI", e -> cards.show(contentArea, "scheda"));
        head.add(l, BorderLayout.WEST);
        head.add(b, BorderLayout.EAST);

        JPanel list = new JPanel();
        list.setOpaque(false);
        list.setLayout(new BoxLayout(list, BoxLayout.Y_AXIS));
        List<Esercizio> es = scheda.getEsercizi();
        if (es.isEmpty()) {
            JLabel empty = new JLabel("Nessun esercizio. Crea la tua scheda.");
            empty.setForeground(MUTED);
            list.add(empty);
        } else {
            for (int i = 0; i < Math.min(5, es.size()); i++) {
                Esercizio e = es.get(i);
                JPanel row = new JPanel(new BorderLayout());
                row.setBackground(SURFACE2);
                row.setBorder(new EmptyBorder(10, 12, 10, 12));
                row.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
                JLabel nm = new JLabel((i + 1) + ".  " + e.getNome());
                nm.setForeground(FG);
                JLabel meta = new JLabel(e.getSerie() + "×" + e.getRipetizioni() + "  ·  " + e.getTempoRecupero() + "s");
                meta.setForeground(MUTED);
                row.add(nm, BorderLayout.WEST);
                row.add(meta, BorderLayout.EAST);
                list.add(row);
                list.add(Box.createVerticalStrut(6));
            }
        }

        p.add(head, BorderLayout.NORTH);
        p.add(list, BorderLayout.CENTER);
        return p;
    }

