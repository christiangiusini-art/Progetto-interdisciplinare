    private void refreshSchedePanel() {
        areaSchedePanel.removeAll();
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(10, 10, 10, 10);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.gridwidth = 1;
        gbc.gridx = 0;
        gbc.gridy = 0;
        
        for (int i = 0; i < listaSchede.size(); i++) {
            SchedaAllenamento sched = listaSchede.get(i);
            JPanel card = creaSchedaCard(sched);
            card.addMouseListener(new MouseAdapter() {
                @Override
                public void mouseClicked(MouseEvent e) {
                    schedaCorrente = sched;
                    JTextArea msg = new JTextArea(sched.getDettagli());
                    msg.setEditable(false);
                    msg.setBackground(BG_CARD);
                    msg.setForeground(TEXT_LIGHT);
                    JScrollPane sp = new JScrollPane(msg);
                    sp.setPreferredSize(new Dimension(500, 400));
                    JOptionPane.showMessageDialog(PalestraGui.this, sp, "Dettagli Scheda", JOptionPane.INFORMATION_MESSAGE);
                }
            });
            areaSchedePanel.add(card, gbc);
            gbc.gridy++;
        }
        
        areaSchedePanel.revalidate();
        areaSchedePanel.repaint();
    }

    private void apriDialogoCreaScheda() {
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBackground(BG_CARD);
        panel.setBorder(new EmptyBorder(20, 20, 20, 20));
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.anchor = GridBagConstraints.WEST;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Nome Scheda:"), gbc);
        gbc.gridx = 1;
        JTextField nomeScheda = new JTextField(20);
        nomeScheda.setBackground(FIELD_BG);
        nomeScheda.setForeground(TEXT_LIGHT);
        nomeScheda.setBorder(BorderFactory.createLineBorder(FIELD_BORDER, 1));
        panel.add(nomeScheda, gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        panel.add(new JLabel("Giorno:"), gbc);
        gbc.gridx = 1;
        String[] giorni = {"Lunedì", "Martedì", "Mercoledì", "Giovedì", "Venerdì", "Sabato", "Domenica"};
        JComboBox<String> comboGiorni = new JComboBox<>(giorni);
        comboGiorni.setBackground(FIELD_BG);
        comboGiorni.setForeground(TEXT_LIGHT);
        panel.add(comboGiorni, gbc);
        
        gbc.gridx = 0; gbc.gridy = 2;
        gbc.gridwidth = 2;
        JPanel buttons = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        
        JButton btnSalva = new JButton("Salva");
        stileBottonePrimary(btnSalva);
        btnSalva.addActionListener(e -> {
            String nome = nomeScheda.getText().trim();
            String giorno = (String) comboGiorni.getSelectedItem();
            
            if (nome.isEmpty()) {
                JOptionPane.showMessageDialog(PalestraGui.this, "Inserisci un nome!", "Errore", JOptionPane.ERROR_MESSAGE);
                return;
            }
            
            SchedaAllenamento nuovaScheda = new SchedaAllenamento();
            listaSchede.add(nuovaScheda);
            schedaCorrente = nuovaScheda;
            
            JOptionPane.showMessageDialog(this, "Scheda creata! Ora puoi aggiungere esercizi.", "Successo", JOptionPane.INFORMATION_MESSAGE);
            refreshSchedePanel();
        });
        
        buttons.add(btnSalva);
        panel.add(buttons, gbc);
        
        JOptionPane.showMessageDialog(this, panel);
    }

    // === MODIFICA SCHEDA CON ESERCIZI ===
    private JPanel creaSchedaCard(SchedaAllenamento sched) {
        JPanel card = new JPanel(new BorderLayout(15, 15));
        card.setBackground(BG_CARD);
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_COLOR, 1),
            new EmptyBorder(15, 15, 15, 15)
        ));
        card.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        
        JPanel info = new JPanel(new FlowLayout(FlowLayout.LEFT, 20, 5));
        JLabel lblNome = new JLabel("📝 " + sched.getNomeScheda());
        lblNome.setFont(new Font("Segoe UI", Font.BOLD, 14));
        lblNome.setForeground(TEXT_LIGHT);
        
        
        info.add(lblNome);
        
        JPanel actions = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        JButton btnModifica = new JButton("✏️ Modifica");
        btnModifica.setBackground(BG_SECONDARY);
        btnModifica.setForeground(TEXT_LIGHT);
        btnModifica.setFocusPainted(false);
        btnModifica.addActionListener(ev -> apriDialogoModificaScheda(sched));
        actions.add(btnModifica);
        
        card.add(info, BorderLayout.CENTER);
        card.add(actions, BorderLayout.EAST);
        
        return card;
    }

    private void apriDialogoModificaScheda(SchedaAllenamento scheda) {
        JPanel dialogPanel = new JPanel(new BorderLayout(15, 15));
        dialogPanel.setBackground(BG_CARD);
        dialogPanel.setBorder(new EmptyBorder(20, 20, 20, 20));
        
        JLabel lblTitolo = new JLabel("📋 Modifica: " + scheda.getNomeScheda());
        lblTitolo.setFont(new Font("Segoe UI", Font.BOLD, 16));
        lblTitolo.setForeground(ACCENT_GOLD);
        dialogPanel.add(lblTitolo, BorderLayout.NORTH);
        
        // Selezione esercizio
        JPanel topPanel = new JPanel(new GridBagLayout());
        topPanel.setBackground(BG_CARD);
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        topPanel.add(new JLabel("Seleziona Esercizio:"), gbc);
        gbc.gridx = 1;
        DefaultComboBoxModel<String> exercModel = new DefaultComboBoxModel<>();
        for (Esercizio e : catalogoEsercizi) {
            exercModel.addElement(e.getNome() + " (" + e.getGruppoMuscolare() + ")");
        }
        JComboBox<String> comboEsercizi = new JComboBox<>(exercModel);
        comboEsercizi.setBackground(FIELD_BG);
        comboEsercizi.setForeground(TEXT_LIGHT);
        comboEsercizi.setMaximumRowCount(10);
        topPanel.add(comboEsercizi, gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        topPanel.add(new JLabel("Serie:"), gbc);
        gbc.gridx = 1;
        SpinnerModel smSerie = new SpinnerNumberModel(3, 1, 10, 1);
        JSpinner spinnerSerie = new JSpinner(smSerie);
        spinnerSerie.setEditor(new JSpinner.NumberEditor(spinnerSerie, "%d"));
        spinnerSerie.setPreferredSize(new Dimension(80, 30));
        topPanel.add(spinnerSerie, gbc);
        
        gbc.gridx = 2;
        topPanel.add(new JLabel("Ripetizioni:"), gbc);
        gbc.gridx = 3;
        SpinnerModel smRep = new SpinnerNumberModel(10, 1, 25, 1);
        JSpinner spinnerRep = new JSpinner(smRep);
        spinnerRep.setEditor(new JSpinner.NumberEditor(spinnerRep, "%d"));
        spinnerRep.setPreferredSize(new Dimension(80, 30));
        topPanel.add(spinnerRep, gbc);
        
        gbc.gridx = 4;
        topPanel.add(new JLabel("Peso (kg):"), gbc);
        gbc.gridx = 5;
        SpinnerModel smPeso = new SpinnerNumberModel(0, 0, 200, 2.5);
        JSpinner spinnerPeso = new JSpinner(smPeso);
        spinnerPeso.setEditor(new JSpinner.NumberEditor(spinnerPeso, "%.1f"));
        spinnerPeso.setPreferredSize(new Dimension(80, 30));
        topPanel.add(spinnerPeso, gbc);
        
        dialogPanel.add(topPanel, BorderLayout.NORTH);
        
        // Lista esercizi aggiunti
        JLabel lblLista = new JLabel("Esercizi nella scheda:");
        lblLista.setForeground(TEXT_LIGHT);
        lblLista.setFont(new Font("Segoe UI", Font.BOLD, 12));
        
        JTextArea taLista = new JTextArea(12, 70);
        taLista.setEditable(false);
        taLista.setBackground(FIELD_BG);
        taLista.setForeground(TEXT_LIGHT);
        taLista.setFont(new Font("Monospaced", Font.PLAIN, 12));
        
        JScrollPane listaScroll = new JScrollPane(taLista);
        dialogPanel.add(listaScroll, BorderLayout.CENTER);
        
        // Aggiorna lista
        
        // Pulsanti
        JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        
        JButton btnAggiungi = new JButton("+ Aggiungi Esercizio");
        stileBottonePrimary(btnAggiungi);
        btnAggiungi.addActionListener(e -> {
            int selectedIndex = comboEsercizi.getSelectedIndex();
            if (selectedIndex >= 0 && selectedIndex < catalogoEsercizi.size()) {
                Esercizio es = catalogoEsercizi.get(selectedIndex);
                int serie = ((Integer) ((SpinnerNumberModel) spinnerSerie.getModel()).getValue()).intValue();
                int rep = ((Integer) ((SpinnerNumberModel) spinnerRep.getModel()).getValue()).intValue();
                double peso = ((Integer) ((SpinnerNumberModel) spinnerPeso.getModel()).getValue()).doubleValue();
                
                scheda.CreaScheda(es, serie, rep, peso);
            }
        });
        
        JButton btnElimina = new JButton("- Rimuovi Ultimo");
        stileBottoneSecondary(btnElimina);
        btnElimina.addActionListener(e -> {
            if (scheda.getNumeroEsercizi() > 0) {
                scheda.eliminaScheda();
            }
        });
        
        JButton btnSalva = new JButton("💾 Salva Modifiche");
        stileBottonePrimary(btnSalva);
        btnSalva.addActionListener(e -> {
            saveDialog(dialogPanel);
            refreshSchedePanel();
            JOptionPane.showMessageDialog(this, "✅ Scheda salvata con successo!", "Successo", JOptionPane.INFORMATION_MESSAGE);
        });
        
        JButton btnAnnulla = new JButton("❌ Annulla");
        stileBottoneSecondary(btnAnnulla);
        btnAnnulla.addActionListener(e -> saveDialog(dialogPanel));
        
        buttonPanel.add(btnAggiungi);
        buttonPanel.add(Box.createHorizontalStrut(10));
        buttonPanel.add(btnElimina);
        buttonPanel.add(Box.createHorizontalStrut(10));
        buttonPanel.add(btnSalva);
        buttonPanel.add(Box.createHorizontalStrut(10));
        buttonPanel.add(btnAnnulla);
        
        dialogPanel.add(buttonPanel, BorderLayout.SOUTH);
        
        
        JOptionPane.showMessageDialog(this, dialogPanel);
    }

    private void saveDialog(Component c) {
        c.getParent().getParent().setVisible(false);
    }

