    // -------- CATALOGO --------
    private JComponent buildCatalogo() {
        JPanel root = new JPanel(new BorderLayout(0, 16));
        root.setBackground(BG);

        JPanel head = new JPanel(new BorderLayout());
        head.setOpaque(false);
        JLabel t = new JLabel("ESERCIZI DISPONIBILI");
        t.setFont(new Font("SansSerif", Font.BOLD, 26));
        t.setForeground(FG);
        JLabel sub = new JLabel("10 esercizi precaricati");
        sub.setForeground(MUTED);
        head.add(t, BorderLayout.WEST);
        head.add(sub, BorderLayout.EAST);

        JPanel grid = new JPanel(new GridLayout(0, 5, 12, 12));
        grid.setOpaque(false);

        Esercizio[] all = SchedaAllenamento.getEserciziDisponibili();
        for (int i = 0; i < all.length; i++) {
            Esercizio e = all[i];
            grid.add(esercizioCard(i + 1, e, true));
        }

        root.add(head, BorderLayout.NORTH);
        root.add(grid, BorderLayout.CENTER);
        return root;
    }

    private JComponent esercizioCard(int idx, Esercizio e, boolean addable) {
        JPanel c = card();
        c.setLayout(new BoxLayout(c, BoxLayout.Y_AXIS));

        JLabel num = new JLabel(String.format("%02d", idx));
        num.setForeground(MUTED);
        num.setFont(num.getFont().deriveFont(Font.BOLD, 11f));
        num.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel nm = new JLabel("<html><b>" + e.getNome().toUpperCase() + "</b></html>");
        nm.setForeground(FG);
        nm.setFont(nm.getFont().deriveFont(Font.BOLD, 15f));
        nm.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel gr = new JLabel(e.getGruppoMuscolare().toUpperCase());
        gr.setForeground(PRIMARY);
        gr.setFont(gr.getFont().deriveFont(Font.PLAIN, 10f));
        gr.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel meta = new JLabel(e.getSerie() + "×" + e.getRipetizioni() + "   ·   " + e.getTempoRecupero() + "s rec");
        meta.setForeground(MUTED);
        meta.setAlignmentX(Component.LEFT_ALIGNMENT);

        c.add(num);
        c.add(Box.createVerticalStrut(6));
        c.add(nm);
        c.add(gr);
        c.add(Box.createVerticalStrut(10));
        c.add(meta);

        if (addable) {
            c.add(Box.createVerticalStrut(10));
            JButton add = primaryButton("+ AGGIUNGI", evt -> {
                if (scheda.aggiungiEsercizio(e)) {
                    JOptionPane.showMessageDialog(this, "Aggiunto a scheda: " + e.getNome());
                    refreshSchedaModel();
                } else {
                    JOptionPane.showMessageDialog(this, "Scheda piena (max " + SchedaAllenamento.MAX_ESERCIZI + ")");
                }
            });
            add.setAlignmentX(Component.LEFT_ALIGNMENT);
            c.add(add);
        }
        return c;
    }

    // -------- SCHEDA --------
    private JComponent buildScheda() {
        JPanel root = new JPanel(new BorderLayout(0, 14));
        root.setBackground(BG);

        // header scheda
        JPanel head = card();
        head.setLayout(new BorderLayout());

        JPanel left = new JPanel();
        left.setOpaque(false);
        left.setLayout(new BoxLayout(left, BoxLayout.Y_AXIS));

        lblNomeScheda = new JLabel(scheda.getNomeScheda() != null ? scheda.getNomeScheda() : "LA MIA SCHEDA");
        lblNomeScheda.setForeground(FG);
        lblNomeScheda.setFont(new Font("SansSerif", Font.BOLD, 24));

        lblObiettivoScheda = new JLabel("Obiettivo: " + (scheda.getObiettivo() != null ? scheda.getObiettivo() : "Ipertrofia"));
        lblObiettivoScheda.setForeground(MUTED);

        lblConteggioEsercizi = new JLabel(scheda.getEsercizi().size() + " / " + SchedaAllenamento.MAX_ESERCIZI + " esercizi");
        lblConteggioEsercizi.setForeground(PRIMARY);

        left.add(lblNomeScheda);
        left.add(lblObiettivoScheda);
        left.add(Box.createVerticalStrut(4));
        left.add(lblConteggioEsercizi);

        JPanel actions = new JPanel(new FlowLayout(FlowLayout.RIGHT, 8, 0));
        actions.setOpaque(false);
        actions.add(secondaryButton("MODIFICA NOME", e -> {
            String n = JOptionPane.showInputDialog(this, "Nome scheda:", scheda.getNomeScheda());
            if (n != null && !n.isBlank()) {
                scheda.setNomeScheda(n);
                lblNomeScheda.setText(n);
            }
        }));
        actions.add(secondaryButton("OBIETTIVO", e -> {
            String o = JOptionPane.showInputDialog(this, "Obiettivo:", scheda.getObiettivo());
            if (o != null && !o.isBlank()) {
                scheda.setObiettivo(o);
                lblObiettivoScheda.setText("Obiettivo: " + o);
            }
        }));
        actions.add(dangerButton("ELIMINA", e -> {
            int r = JOptionPane.showConfirmDialog(this, "Svuotare la scheda?", "Conferma", JOptionPane.YES_NO_OPTION);
            if (r == JOptionPane.YES_OPTION) { scheda.svuota(); refreshSchedaModel(); }
        }));

        head.add(left, BorderLayout.WEST);
        head.add(actions, BorderLayout.EAST);

        // tabella esercizi
        modelloScheda = new DefaultTableModel(
            new Object[]{"#", "Esercizio", "Gruppo", "Serie", "Reps", "Recupero (s)"}, 0) {
            @Override public boolean isCellEditable(int r, int c) { return false; }
        };
        JTable table = new JTable(modelloScheda);
        styleTable(table);
        refreshSchedaModel();

        JScrollPane sp = new JScrollPane(table);
        sp.getViewport().setBackground(SURFACE);
        sp.setBorder(new LineBorder(BORDER));

        JPanel tableCard = card();
        tableCard.setLayout(new BorderLayout(0, 10));

        JPanel tHead = new JPanel(new BorderLayout());
        tHead.setOpaque(false);
        JLabel th = new JLabel("ESERCIZI IN SCHEDA");
        th.setForeground(FG);
        th.setFont(new Font("SansSerif", Font.BOLD, 16));
        JPanel tActions = new JPanel(new FlowLayout(FlowLayout.RIGHT, 8, 0));
        tActions.setOpaque(false);
        tActions.add(primaryButton("+ AGGIUNGI DAL CATALOGO", e -> cards.show(contentArea, "catalogo")));
        tActions.add(dangerButton("RIMUOVI SELEZIONATO", e -> {
            int row = table.getSelectedRow();
            if (row < 0) { JOptionPane.showMessageDialog(this, "Seleziona un esercizio."); return; }
            scheda.rimuoviEsercizio(row);
            refreshSchedaModel();
        }));
        tHead.add(th, BorderLayout.WEST);
        tHead.add(tActions, BorderLayout.EAST);

        tableCard.add(tHead, BorderLayout.NORTH);
        tableCard.add(sp, BorderLayout.CENTER);

        root.add(head, BorderLayout.NORTH);
        root.add(tableCard, BorderLayout.CENTER);
        return root;
    }

    private void refreshSchedaModel() {
        if (modelloScheda == null) return;
        modelloScheda.setRowCount(0);
        List<Esercizio> es = scheda.getEsercizi();
        for (int i = 0; i < es.size(); i++) {
            Esercizio e = es.get(i);
            modelloScheda.addRow(new Object[]{
                String.format("%02d", i + 1),
                e.getNome(), e.getGruppoMuscolare(),
                e.getSerie(), e.getRipetizioni(), e.getTempoRecupero()
            });
        }
        if (lblConteggioEsercizi != null)
            lblConteggioEsercizi.setText(es.size() + " / " + SchedaAllenamento.MAX_ESERCIZI + " esercizi");
    }

    private void styleTable(JTable t) {
        t.setBackground(SURFACE);
        t.setForeground(FG);
        t.setGridColor(BORDER);
        t.setRowHeight(36);
        t.setSelectionBackground(PRIMARY_DK);
        t.setSelectionForeground(Color.WHITE);
        t.setShowVerticalLines(false);
        t.setIntercellSpacing(new Dimension(0, 1));
        JTableHeader h = t.getTableHeader();
        h.setBackground(SURFACE2);
        h.setForeground(MUTED);
        h.setFont(h.getFont().deriveFont(Font.BOLD, 11f));
        h.setBorder(new MatteBorder(0, 0, 1, 0, BORDER));
    }

    // -------- PALESTRA --------
    private JComponent buildPalestra() {
        JPanel root = new JPanel(new BorderLayout(0, 16));
        root.setBackground(BG);

        JLabel t = new JLabel("ORARI SETTIMANALI");
        t.setForeground(FG);
        t.setFont(new Font("SansSerif", Font.BOLD, 26));

        JPanel grid = new JPanel(new GridLayout(1, 7, 10, 10));
        grid.setOpaque(false);
        for (int i = 0; i < Palestra.giorni.length; i++) {
            JPanel c = card();
            c.setLayout(new BoxLayout(c, BoxLayout.Y_AXIS));
            JLabel g = new JLabel(Palestra.giorni[i].toUpperCase());
            g.setForeground(PRIMARY);
            g.setFont(g.getFont().deriveFont(Font.BOLD, 12f));
            g.setAlignmentX(Component.CENTER_ALIGNMENT);
            JLabel ore = new JLabel(String.format("%02d:00 — %02d:00",
                Palestra.orarioApertura[i], Palestra.orarioChiusura[i]));
            ore.setForeground(FG);
            ore.setAlignmentX(Component.CENTER_ALIGNMENT);
            JLabel st = new JLabel("APERTA");
            st.setForeground(SECONDARY);
            st.setFont(st.getFont().deriveFont(Font.BOLD, 10f));
            st.setAlignmentX(Component.CENTER_ALIGNMENT);
            c.add(g);
            c.add(Box.createVerticalStrut(8));
            c.add(ore);
            c.add(Box.createVerticalStrut(8));
            c.add(st);
            grid.add(c);
        }

        JPanel abb = card();
        abb.setLayout(new BorderLayout(12, 0));
        JPanel l = new JPanel();
        l.setOpaque(false);
        l.setLayout(new BoxLayout(l, BoxLayout.Y_AXIS));
        JLabel a1 = new JLabel("ABBONAMENTO ANNUALE");
        a1.setForeground(MUTED);
        a1.setFont(a1.getFont().deriveFont(Font.BOLD, 10f));
        JLabel a2 = new JLabel("€ " + (int) Palestra.costoAnnuale + " / anno");
        a2.setForeground(FG);
        a2.setFont(new Font("SansSerif", Font.BOLD, 28));
        JLabel a3 = new JLabel("oppure € " + (int) Palestra.costoMensile + " / mese");
        a3.setForeground(MUTED);
        l.add(a1); l.add(a2); l.add(a3);

        JButton sub = primaryButton("SOTTOSCRIVI",
            e -> JOptionPane.showMessageDialog(this, "Abbonamento confermato!"));
        abb.add(l, BorderLayout.WEST);
        abb.add(sub, BorderLayout.EAST);

        JPanel center = new JPanel(new BorderLayout(0, 14));
        center.setOpaque(false);
        center.add(grid, BorderLayout.NORTH);
        center.add(abb, BorderLayout.CENTER);

        root.add(t, BorderLayout.NORTH);
        root.add(center, BorderLayout.CENTER);
        return root;
    }

    // -------- UTENTE --------
    private JComponent buildUtente() {
        JPanel root = new JPanel(new BorderLayout(0, 16));
        root.setBackground(BG);

        JLabel t = new JLabel("PROFILO UTENTE");
        t.setForeground(FG);
        t.setFont(new Font("SansSerif", Font.BOLD, 26));

        JPanel c = card();
        c.setLayout(new GridLayout(0, 2, 12, 10));
        addField(c, "Nome",     utente.getNome());
        addField(c, "Cognome",  utente.getCognome());
        addField(c, "Età",      String.valueOf(utente.getEta()));
        addField(c, "Username", utente.getUsername());
        addField(c, "Email",    utente.getEmail());
        addField(c, "Telefono", String.valueOf(utente.getNumTelefono()));
        addField(c, "Peso",     utente.getPeso() + " kg");
        addField(c, "Altezza",  utente.getAltezza() + " cm");

        root.add(t, BorderLayout.NORTH);
        root.add(c, BorderLayout.CENTER);
        return root;
    }

    private void addField(JPanel parent, String k, String v) {
        JPanel row = new JPanel(new BorderLayout());
        row.setBackground(SURFACE2);
        row.setBorder(new EmptyBorder(12, 14, 12, 14));
        JLabel kl = new JLabel(k.toUpperCase());
        kl.setForeground(MUTED);
        kl.setFont(kl.getFont().deriveFont(Font.BOLD, 10f));
        JLabel vl = new JLabel(v == null ? "—" : v);
        vl.setForeground(FG);
        row.add(kl, BorderLayout.NORTH);
        row.add(vl, BorderLayout.SOUTH);
        parent.add(row);
    }

    // ==================== UI HELPERS ====================
    private JPanel card() {
        JPanel p = new JPanel();
        p.setBackground(SURFACE);
        p.setBorder(new CompoundBorder(
            new LineBorder(BORDER), new EmptyBorder(18, 20, 18, 20)));
        return p;
    }

    private JLabel pill(String text) {
        JLabel l = new JLabel("  " + text + "  ");
        l.setOpaque(true);
        l.setBackground(new Color(PRIMARY.getRed(), PRIMARY.getGreen(), PRIMARY.getBlue(), 40));
        l.setForeground(PRIMARY);
        l.setFont(l.getFont().deriveFont(Font.BOLD, 10f));
        l.setBorder(new LineBorder(PRIMARY_DK));
        return l;
    }

    private JPanel statCard(String label, String value) {
        JPanel p = new JPanel();
        p.setBackground(SURFACE2);
        p.setBorder(new CompoundBorder(new LineBorder(BORDER), new EmptyBorder(14, 14, 14, 14)));
        p.setLayout(new BoxLayout(p, BoxLayout.Y_AXIS));
        JLabel v = new JLabel(value);
        v.setForeground(FG);
        v.setFont(new Font("SansSerif", Font.BOLD, 22));
        JLabel l = new JLabel(label.toUpperCase());
        l.setForeground(MUTED);
        l.setFont(l.getFont().deriveFont(Font.BOLD, 10f));
        p.add(v); p.add(Box.createVerticalStrut(4)); p.add(l);
        return p;
    }

    private JButton primaryButton(String text, ActionListener a) {
        JButton b = new JButton(text);
        b.setBackground(PRIMARY);
        b.setForeground(Color.WHITE);
        b.setFocusPainted(false);
        b.setBorder(new EmptyBorder(10, 18, 10, 18));
        b.setFont(b.getFont().deriveFont(Font.BOLD, 12f));
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        b.addActionListener(a);
        return b;
    }

    private JButton secondaryButton(String text, ActionListener a) {
        JButton b = new JButton(text);
        b.setBackground(SURFACE2);
        b.setForeground(FG);
        b.setFocusPainted(false);
        b.setBorder(new CompoundBorder(new LineBorder(BORDER), new EmptyBorder(10, 16, 10, 16)));
        b.setFont(b.getFont().deriveFont(Font.BOLD, 12f));
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        b.addActionListener(a);
        return b;
    }

    private JButton dangerButton(String text, ActionListener a) {
        JButton b = new JButton(text);
        b.setBackground(new Color(DESTRUCTIVE.getRed(), DESTRUCTIVE.getGreen(), DESTRUCTIVE.getBlue(), 60));
        b.setForeground(new Color(0xFF8A7A));
        b.setFocusPainted(false);
        b.setBorder(new CompoundBorder(new LineBorder(DESTRUCTIVE), new EmptyBorder(10, 16, 10, 16)));
        b.setFont(b.getFont().deriveFont(Font.BOLD, 12f));
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        b.addActionListener(a);
        return b;
    }
