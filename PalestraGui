        infoCosti.add(new JLabel("Sconto Under 18: " + palestra.getScontoUnder18() + "%"));
        infoCosti.add(new JLabel("Sconto Over 65: " + palestra.getScontoOver65() + "%"));
        
        JPanel selectionPanel = new JPanel(new GridLayout(3, 2, 10, 10));
        selectionPanel.setBorder(BorderFactory.createTitledBorder("📋 Scegli Abbonamento"));
        
        JRadioButton mensileBtn = new JRadioButton("Mensile");
        JRadioButton annualeBtn = new JRadioButton("Annuale");
        ButtonGroup group = new ButtonGroup();
        group.add(mensileBtn);
        group.add(annualeBtn);
        mensileBtn.setSelected(true);
        
        JLabel etaLabel = new JLabel("Inserisci età per calcolo sconti:");
        JTextField etaField = new JTextField(10);
        JButton calcolaBtn = new JButton("💰 Calcola Costo");
        JLabel risultatoLabel = new JLabel("Costo: -- €");
        risultatoLabel.setFont(new Font("Arial", Font.BOLD, 16));
        risultatoLabel.setForeground(new Color(33, 150, 243));
        
        selectionPanel.add(mensileBtn);
        selectionPanel.add(annualeBtn);
        selectionPanel.add(etaLabel);
        selectionPanel.add(etaField);
        selectionPanel.add(calcolaBtn);
        selectionPanel.add(risultatoLabel);
        
        calcolaBtn.addActionListener(e -> {
            if (utenteCorrente == null) {
                JOptionPane.showMessageDialog(this, "Prima crea un utente nella sezione Utente!");
                return;
            }
            
            try {
                int eta = Integer.parseInt(etaField.getText());
                boolean annuale = annualeBtn.isSelected();
                double costo = palestra.calcolaCosto(eta, annuale);
                risultatoLabel.setText("Costo: €" + String.format("%.2f", costo));
                log("Calcolato costo " + (annuale ? "annuale" : "mensile") + ": €" + costo + " per età " + eta);
                
                int conferma = JOptionPane.showConfirmDialog(this, 
                    "Costo totale: €" + String.format("%.2f", costo) + "\nConfermi l'acquisto?",
                    "Conferma Acquisto",
                    JOptionPane.YES_NO_OPTION);
                    
                if (conferma == JOptionPane.YES_OPTION) {
                    utenteCorrente.setTipoAbbonamento(annuale ? "Annuale" : "Mensile");
                    utenteCorrente.setAbbonamentoAttivo(true);
                    log("✅ Abbonamento " + (annuale ? "annuale" : "mensile") + " attivato per " + 
                        utenteCorrente.getNomeCompleto());
                    JOptionPane.showMessageDialog(this, "Abbonamento attivato con successo!");
                }
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this, "Inserisci un'età valida!");
            }
        });
        
        gbc.gridx = 0; gbc.gridy = 0;
        panelAbbonamento.add(infoCosti, gbc);
        gbc.gridy = 1;
        panelAbbonamento.add(selectionPanel, gbc);
    }
    
