    private JPanel createTrainerListPanel() {
        JPanel panel = new JPanel(new BorderLayout(5, 5));
        panel.setBorder(BorderFactory.createTitledBorder("📋 Personal Trainer Disponibili"));
        
        String[] colonne = {"Nome", "Specializzazione", "Esperienza", "Costo/ora", "Disponibile"};
        DefaultTableModel modelTrainer = new DefaultTableModel(colonne, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        for (PersonalTrainer pt : PersonalTrainer.getTrainerDisponibili()) {
            modelTrainer.addRow(new Object[]{
                pt.getNomeCompleto(),
                pt.getSpecializzazione(),
                pt.getAnniEsperienza() + " anni",
                "€" + pt.getCostoOrario(),
                pt.isDisponibile() ? "✅ Sì" : "❌ No"
            });
        }
        
        JTable tableTrainer = new JTable(modelTrainer);
        tableTrainer.setRowHeight(30);
        tableTrainer.getTableHeader().setFont(new Font("Arial", Font.BOLD, 12));
        
        JScrollPane scrollPane = new JScrollPane(tableTrainer);
        panel.add(scrollPane, BorderLayout.CENTER);
        
        JTextArea dettagliArea = new JTextArea(8, 30);
        dettagliArea.setEditable(false);
        dettagliArea.setFont(new Font("Monospaced", Font.PLAIN, 11));
        JScrollPane scrollDettagli = new JScrollPane(dettagliArea);
        scrollDettagli.setBorder(BorderFactory.createTitledBorder("📝 Dettagli Trainer"));
        panel.add(scrollDettagli, BorderLayout.SOUTH);
        
        tableTrainer.getSelectionModel().addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                int row = tableTrainer.getSelectedRow();
                if (row >= 0) {
                    PersonalTrainer pt = PersonalTrainer.getTrainerByIndex(row);
                    if (pt != null) {
                        StringBuilder sb = new StringBuilder();
                        sb.append("👤 Nome: ").append(pt.getNomeCompleto()).append("\n");
                        sb.append("🎯 Specializzazione: ").append(pt.getSpecializzazione()).append("\n");
                        sb.append("📅 Esperienza: ").append(pt.getAnniEsperienza()).append(" anni\n");
                        sb.append("💰 Costo orario: €").append(pt.getCostoOrario()).append("\n");
                        sb.append("📜 Certificazioni:\n");
                        for (String cert : pt.getCertificazioni()) {
                            sb.append("   • ").append(cert).append("\n");
                        }
                        sb.append("📌 Disponibilità: ").append(pt.isDisponibile() ? "Disponibile" : "Non disponibile");
                        dettagliArea.setText(sb.toString());
                    }
                }
            }
        });
        
        return panel;
    }
    
    private JPanel createRichiestaPanel() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBorder(BorderFactory.createTitledBorder("📝 Richiedi Personal Trainer"));
        
        JPanel formPanel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(8, 8, 8, 8);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        // Obiettivo
        gbc.gridx = 0; gbc.gridy = 0;
        formPanel.add(new JLabel("Obiettivo:"), gbc);
        gbc.gridx = 1;
        JComboBox<String> obiettivoCombo = new JComboBox<>(new String[]{
            "Massa Muscolare", "Dimagrimento", "Tonificazione", "Preparazione Atletica", "Riabilitazione", "Mantenimento"
        });
        formPanel.add(obiettivoCombo, gbc);
        
        // Sedute settimanali
        gbc.gridx = 0; gbc.gridy = 1;
        formPanel.add(new JLabel("Sedute a settimana:"), gbc);
        gbc.gridx = 1;
        JSpinner seduteSpinner = new JSpinner(new SpinnerNumberModel(2, 1, 7, 1));
        formPanel.add(seduteSpinner, gbc);
        
        // Fascia oraria preferita
        gbc.gridx = 0; gbc.gridy = 2;
        formPanel.add(new JLabel("Fascia oraria:"), gbc);
        gbc.gridx = 1;
        JComboBox<String> fasciaCombo = new JComboBox<>(new String[]{
            "Mattina (8:00-12:00)", "Pomeriggio (14:00-18:00)", "Sera (18:00-22:00)", "Flessibile"
        });
        formPanel.add(fasciaCombo, gbc);
        
        // Note aggiuntive
        gbc.gridx = 0; gbc.gridy = 3;
        formPanel.add(new JLabel("Note aggiuntive:"), gbc);
        gbc.gridx = 1;
        JTextArea noteArea = new JTextArea(3, 20);
        noteArea.setLineWrap(true);
        JScrollPane noteScroll = new JScrollPane(noteArea);
        formPanel.add(noteScroll, gbc);
        
        // Bottone invia richiesta
        JButton inviaBtn = new JButton("📨 Invia Richiesta");
        inviaBtn.setBackground(new Color(33, 150, 243));
        inviaBtn.setForeground(Color.WHITE);
        inviaBtn.setFont(new Font("Arial", Font.BOLD, 14));
        
        JPanel buttonPanel = new JPanel(new FlowLayout());
        buttonPanel.add(inviaBtn);
        
        // Area per visualizzare le richieste esistenti
        JPanel richiestePanel = new JPanel(new BorderLayout());
        richiestePanel.setBorder(BorderFactory.createTitledBorder("📋 Le tue Richieste"));
        
        DefaultTableModel modelRichieste = new DefaultTableModel(
            new String[]{"ID", "Trainer", "Obiettivo", "Sedute/sett", "Stato", "Data"}, 0
        ) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        JTable tableRichieste = new JTable(modelRichieste);
        tableRichieste.setRowHeight(25);
        JScrollPane scrollRichieste = new JScrollPane(tableRichieste);
        richiestePanel.add(scrollRichieste, BorderLayout.CENTER);
        
        JButton aggiornaBtn = new JButton("🔄 Aggiorna Stato Richieste");
        richiestePanel.add(aggiornaBtn, BorderLayout.SOUTH);
        
        // Funzione per aggiornare la lista richieste
        Runnable aggiornaListaRichieste = () -> {
            modelRichieste.setRowCount(0);
            if (utenteCorrente != null) {
                SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
                for (RichiestaPersonalTrainer r : RichiestaPersonalTrainer.getRichiestePerUtente(utenteCorrente)) {
                    String statoEmoji;
                    switch (r.getStato()) {
                        case "In attesa": statoEmoji = "⏳"; break;
                        case "Approvata": statoEmoji = "✅"; break;
                        case "Rifiutata": statoEmoji = "❌"; break;
                        case "Completata": statoEmoji = "🏆"; break;
                        default: statoEmoji = "📌";
                    }
                    modelRichieste.addRow(new Object[]{
                        r.getId(),
                        r.getTrainerScelto().getNomeCompleto(),
                        r.getObiettivo(),
                        r.getSeduteSettimanali(),
                        statoEmoji + " " + r.getStato(),
                        sdf.format(r.getDataRichiesta())
                    });
                }
            }
        };
        
        inviaBtn.addActionListener(e -> {
            if (utenteCorrente == null) {
                JOptionPane.showMessageDialog(this, "Prima crea un utente nella sezione Utente!");
                return;
            }
            
            // Ottieni il trainer selezionato dalla tabella
            Component leftComponent = ((JSplitPane)panelPersonalTrainer.getComponent(0)).getLeftComponent();
            JPanel leftPanel = (JPanel) leftComponent;
            JScrollPane scrollPaneTrainer = (JScrollPane) leftPanel.getComponent(0);
            JTable tableTrainer = (JTable) scrollPaneTrainer.getViewport().getView();
            int selectedRow = tableTrainer.getSelectedRow();
            
            if (selectedRow == -1) {
                JOptionPane.showMessageDialog(this, "Seleziona un Personal Trainer dalla lista!");
                return;
            }
            
            PersonalTrainer trainer = PersonalTrainer.getTrainerByIndex(selectedRow);
            if (!trainer.isDisponibile()) {
                JOptionPane.showMessageDialog(this, "Questo trainer non è attualmente disponibile!");
                return;
            }
            
            int conferma = JOptionPane.showConfirmDialog(this,
                "Confermi la richiesta per il Personal Trainer " + trainer.getNomeCompleto() + "?\n\n" +
                "Obiettivo: " + obiettivoCombo.getSelectedItem() + "\n" +
                "Sedute settimanali: " + seduteSpinner.getValue() + "\n" +
                "Costo mensile stimato: €" + ((Integer)seduteSpinner.getValue() * 4 * trainer.getCostoOrario()) + "\n\n" +
                "Un nostro operatore ti contatterà per confermare l'assegnazione.",
                "Conferma Richiesta",
                JOptionPane.YES_NO_OPTION);
            
            if (conferma == JOptionPane.YES_OPTION) {
                RichiestaPersonalTrainer richiesta = new RichiestaPersonalTrainer(
                    utenteCorrente,
                    trainer,
                    (String) obiettivoCombo.getSelectedItem(),
                    (Integer) seduteSpinner.getValue(),
                    (String) fasciaCombo.getSelectedItem(),
                    noteArea.getText()
                );
                
                RichiestaPersonalTrainer.aggiungiRichiesta(richiesta);
                aggiornaListaRichieste.run();
                
                log("📨 Nuova richiesta Personal Trainer inviata: " + trainer.getNomeCompleto());
                JOptionPane.showMessageDialog(this, "Richiesta inviata con successo!\nID Richiesta: " + richiesta.getId());
                noteArea.setText("");
            }
        });
        
        aggiornaBtn.addActionListener(e -> aggiornaListaRichieste.run());
        
        panel.add(formPanel, BorderLayout.NORTH);
        panel.add(buttonPanel, BorderLayout.CENTER);
        panel.add(richiestePanel, BorderLayout.SOUTH);
        
        return panel;
    }
    
