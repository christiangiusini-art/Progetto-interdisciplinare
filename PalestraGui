    private double calcolaCostoAbbonamento() {
        String tipo = utente.getTipoAbbonamento();
        int eta = utente.getEta();
        
        if (tipo.equals("Mensile")) {
            return palestra.calcolaCosto(eta, false);
        } else if (tipo.equals("Annuale")) {
            return palestra.calcolaCosto(eta, true);
        }
        return 0.0;
    }
    
    private void attivaAbbonamento() {
        String tipo = (String) cmbTipoAbbonamento.getSelectedItem();
        if (tipo.equals("Nessuno")) {
            JOptionPane.showMessageDialog(this, "Seleziona un tipo di abbonamento!", "Errore", JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        utente.setTipoAbbonamento(tipo);
        
        double costo = calcolaCostoAbbonamento();
        int eta = utente.getEta();
        String scontoMsg = "";
        if (eta < 18) {
            scontoMsg = "\n✨ Applico sconto Under 18 (-20%)";
        } else if (eta >= 65) {
            scontoMsg = "\n✨ Applico sconto Over 65 (-15%)";
        }
        
        JOptionPane.showMessageDialog(this, 
            "✅ Abbonamento ATTIVATO!\n\nTipo: " + tipo + 
            "\nCosto: " + String.format("%.2f EUR", costo) + scontoMsg,
            "Abbonamento Attivato", JOptionPane.INFORMATION_MESSAGE);
        
        refreshDashboard();
    }
    
    private void disattivaAbbonamento() {
        int result = JOptionPane.showConfirmDialog(
            this, 
            "Vuoi davvero DISATTIVARE il tuo abbonamento?",
            "Conferma Disattivazione",
            JOptionPane.YES_NO_OPTION
        );
        
        if (result == JOptionPane.YES_OPTION) {
            utente.setTipoAbbonamento("Nessuno");
            cmbTipoAbbonamento.setSelectedItem("Nessuno");
            
            JOptionPane.showMessageDialog(this, 
                "❌ Abbonamento DISATTIVATO",
                "Operazione Completa", JOptionPane.INFORMATION_MESSAGE);
            
            refreshDashboard();
        }
    }
    
