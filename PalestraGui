    private void aggiungiEsercizioAScheda() {
        if (schedaCorrente == null) {
            JOptionPane.showMessageDialog(this, "Crea prima una scheda!");
            return;
        }
        
        int row = tableEserciziDisponibili.getSelectedRow();
        if (row == -1) {
            JOptionPane.showMessageDialog(this, "Seleziona un esercizio dal catalogo!");
            return;
        }
        
        Esercizio original = eserciziDisponibili[row];
        
        JPanel dialogPanel = new JPanel(new GridLayout(4, 2, 10, 10));
        dialogPanel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        
        JTextField serieField = new JTextField(String.valueOf(original.getSerie()));
        JTextField repField = new JTextField(String.valueOf(original.getRipetizioni()));
        JTextField recuperoField = new JTextField(String.valueOf(original.getTempoRecupero()));
        JCheckBox personalizzaCheck = new JCheckBox("Personalizza serie/ripetizioni");
        
        dialogPanel.add(new JLabel("Serie:"));
        dialogPanel.add(serieField);
        dialogPanel.add(new JLabel("Ripetizioni:"));
        dialogPanel.add(repField);
        dialogPanel.add(new JLabel("Recupero (s):"));
        dialogPanel.add(recuperoField);
        dialogPanel.add(personalizzaCheck);
        
        int result = JOptionPane.showConfirmDialog(this, dialogPanel, 
            "Aggiungi: " + original.getNome(), 
            JOptionPane.OK_CANCEL_OPTION);
            
        if (result == JOptionPane.OK_OPTION) {
            Esercizio nuovo;
            if (personalizzaCheck.isSelected()) {
                nuovo = new Esercizio(
                    original.getNome(),
                    original.getGruppoMuscolare(),
                    Integer.parseInt(serieField.getText()),
                    Integer.parseInt(repField.getText()),
                    Integer.parseInt(recuperoField.getText())
                );
            } else {
                nuovo = new Esercizio(
                    original.getNome(),
                    original.getGruppoMuscolare(),
                    original.getSerie(),
                    original.getRipetizioni(),
                    original.getTempoRecupero()
                );
            }
            
            if (schedaCorrente.aggiungiEsercizio(nuovo)) {
                modelEserciziScheda.addRow(new Object[]{
                    modelEserciziScheda.getRowCount() + 1,
                    nuovo.getNome(),
                    nuovo.getGruppoMuscolare(),
                    nuovo.getSerie(),
                    nuovo.getRipetizioni(),
                    nuovo.getTempoRecupero()
                });
                log("➕ Aggiunto esercizio: " + nuovo.getNome());
            } else {
                JOptionPane.showMessageDialog(this, "Scheda piena! Massimo 10 esercizi.");
            }
        }
    }
    
    private void rimuoviEsercizioDaScheda() {
        int row = tableEserciziScheda.getSelectedRow();
        if (row == -1 || schedaCorrente == null) {
            JOptionPane.showMessageDialog(this, "Seleziona un esercizio dalla scheda!");
            return;
        }
        
        schedaCorrente.rimuoviEsercizio(row);
        modelEserciziScheda.removeRow(row);
        
        for (int i = 0; i < modelEserciziScheda.getRowCount(); i++) {
            modelEserciziScheda.setValueAt(i + 1, i, 0);
        }
        
        log("➖ Rimosso esercizio dalla scheda");
    }
    
    private void modificaEsercizioScheda() {
        int row = tableEserciziScheda.getSelectedRow();
        if (row == -1 || schedaCorrente == null || schedaCorrente.getEsercizi()[row] == null) {
            JOptionPane.showMessageDialog(this, "Seleziona un esercizio dalla scheda!");
            return;
        }
        
        Esercizio es = schedaCorrente.getEsercizi()[row];
        
        JPanel dialogPanel = new JPanel(new GridLayout(3, 2, 10, 10));
        JTextField serieField = new JTextField(String.valueOf(es.getSerie()));
        JTextField repField = new JTextField(String.valueOf(es.getRipetizioni()));
        JTextField recuperoField = new JTextField(String.valueOf(es.getTempoRecupero()));
        
        dialogPanel.add(new JLabel("Serie:"));
        dialogPanel.add(serieField);
        dialogPanel.add(new JLabel("Ripetizioni:"));
        dialogPanel.add(repField);
        dialogPanel.add(new JLabel("Recupero (s):"));
        dialogPanel.add(recuperoField);
        
        int result = JOptionPane.showConfirmDialog(this, dialogPanel, 
            "Modifica: " + es.getNome(),
            JOptionPane.OK_CANCEL_OPTION);
            
        if (result == JOptionPane.OK_OPTION) {
            try {
                es.setSerie(Integer.parseInt(serieField.getText()));
                es.setRipetizioni(Integer.parseInt(repField.getText()));
                es.setTempoRecupero(Integer.parseInt(recuperoField.getText()));
                
                modelEserciziScheda.setValueAt(es.getSerie(), row, 3);
                modelEserciziScheda.setValueAt(es.getRipetizioni(), row, 4);
                modelEserciziScheda.setValueAt(es.getTempoRecupero(), row, 5);
                
                log("✏️ Modificato esercizio: " + es.getNome());
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this, "Inserisci numeri validi!");
            }
        }
    }
    
    private void visualizzaSchedaCompleta() {
        if (schedaCorrente == null || schedaCorrente.getNumeroEsercizi() == 0) {
            JOptionPane.showMessageDialog(this, "Nessuna scheda presente!");
            return;
        }
        
        StringBuilder sb = new StringBuilder();
        sb.append("==============================================\n");
        sb.append("         SCHEDA ALLENAMENTO                   \n");
        sb.append("==============================================\n");
        sb.append("Nome: ").append(schedaCorrente.getNomeScheda()).append("\n");
        sb.append("Obiettivo: ").append(schedaCorrente.getObiettivo()).append("\n");
        if (utenteCorrente != null) {
            sb.append("Utente: ").append(utenteCorrente.getNomeCompleto()).append("\n");
        }
        sb.append("----------------------------------------------\n");
        sb.append("ESERCIZI:\n\n");
        
        for (int i = 0; i < schedaCorrente.getNumeroEsercizi(); i++) {
            sb.append((i+1)).append(". ").append(schedaCorrente.getEsercizi()[i].toString()).append("\n");
        }
        
        sb.append("\n==============================================\n");
        
        JTextArea textArea = new JTextArea(sb.toString());
        textArea.setFont(new Font("Monospaced", Font.PLAIN, 12));
        textArea.setEditable(false);
        
        JScrollPane scrollPane = new JScrollPane(textArea);
        scrollPane.setPreferredSize(new Dimension(500, 400));
        
        JOptionPane.showMessageDialog(this, scrollPane, "Scheda Allenamento", JOptionPane.INFORMATION_MESSAGE);
    }
    
