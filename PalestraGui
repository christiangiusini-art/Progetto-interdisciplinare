    private void salvaProfiloUtente() {
        try {
            utente.setNome(txtNome.getText().trim());
            utente.setCognome(txtCognome.getText().trim());
            
            String etaTxt = txtEta.getText().trim();
            if (!etaTxt.isEmpty()) {
                utente.setEta(Integer.parseInt(etaTxt));
            }
            
            utente.setUsername(txtUsername.getText().trim());
            utente.setEmail(txtEmail.getText().trim());
            utente.setTelefono(txtTelefono.getText().trim());
            
            String pesoTxt = txtPeso.getText().trim();
            if (!pesoTxt.isEmpty()) {
                utente.setPeso(Double.parseDouble(pesoTxt));
            }
            
            String altezzaTxt = txtAltezza.getText().trim();
            if (!altezzaTxt.isEmpty()) {
                utente.setAltezza(Double.parseDouble(altezzaTxt));
            }
            
            JOptionPane.showMessageDialog(this, 
                "✅ Profilo aggiornato!\n" + utente.getNomeCompleto(),
                "Successo", JOptionPane.INFORMATION_MESSAGE);
                
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, 
                "⚠️ Inserisci valori numerici validi!", 
                "Errore", JOptionPane.ERROR_MESSAGE);
        }
    }

