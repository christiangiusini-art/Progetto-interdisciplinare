    // ==================== DISPONIBILITA ====================

    private void controllaDisponibilita() {

        try {

            String[] giorni = {
                    "Lunedì",
                    "Martedì",
                    "Mercoledì",
                    "Giovedì",
                    "Venerdì",
                    "Sabato",
                    "Domenica"
            };

            int giorno = JOptionPane.showOptionDialog(
                    this,
                    "Scegli giorno",
                    "Disponibilità",
                    JOptionPane.DEFAULT_OPTION,
                    JOptionPane.INFORMATION_MESSAGE,
                    null,
                    giorni,
                    giorni[0]
            );

            int ora = Integer.parseInt(
                    JOptionPane.showInputDialog(this, "Inserisci ora (0-23)")
            );

            String risultato = Palestra.disponibilitaPalestra(giorno, ora);

            areaOutput.setText(risultato);

        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Errore controllo disponibilità");
        }
    }

