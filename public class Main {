import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        Utente utente = new Utente();

        utente.inserisciDati(scanner);

        System.out.println("Benvenuto " + utente.getUsername());

        String scelta;

        do {
            System.out.print("Vuoi visualizzare le tue informazioni? (s/n): ");
            scelta = scanner.nextLine();

            if (!scelta.equalsIgnoreCase("s") && !scelta.equalsIgnoreCase("n")) {
                System.out.println("Scelta non valida! Inserisci solo 'S' o 'N'.");
            }

        } while (!scelta.equalsIgnoreCase("s") && !scelta.equalsIgnoreCase("n"));

        if (scelta.equalsIgnoreCase("s")) {
            utente.mostraInformazioni();
        }

        Palestra palestra = new Palestra();

        System.out.println("GESTIONE PALESTRA");

        // Inserimento dati
        palestra.inserisciDati(scanner);

        System.out.println("DATI INSERITI : ");
        System.out.println(palestra);

        // Sconti
        System.out.println("CALCOLO SCONTI");

        double annuo = Palestra.scontoCostoAnnuale(Palestra.costoAnnuale, palestra.getUtente().getEta());
        double mensile = Palestra.scontoCostoMensile(Palestra.costoMensile, palestra.getUtente().getEta());

        System.out.println("Costo annuale scontato: " + annuo);
        System.out.println("Costo mensile scontato: " + mensile);

        // Disponibilità palestra
        System.out.println("DISPONIBILITÀ");
        System.out.println(palestra.disponibilitaPalestra());

        // Scheda allenamento
        System.out.println("SCHEDA ALLENAMENTO PERSONALIZZATA");

        System.out.print("Inserisci il tuo peso (kg): ");
        double peso = scanner.nextDouble();

        System.out.print("Inserisci la tua altezza (m): ");
        double altezza = scanner.nextDouble();

        System.out.println(palestra.creaSchedaAllenamento(peso, altezza));

        scanner.close();
    }
}
